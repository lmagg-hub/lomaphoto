# Site URL (für SEO, Sitemap, OG Tags)
NEXT_PUBLIC_SITE_URL=https://lomaphoto.at

# Sanity CMS — Projekt auf https://www.sanity.io/manage erstellen
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optionaler Read-Token für private Datensätze
# SANITY_API_READ_TOKEN=your_read_token_here

# Für Kontaktformular (optional: Resend, SendGrid, etc.)
# CONTACT_EMAIL=hello@lomaphoto.at
